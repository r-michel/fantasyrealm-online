{% extends 'base.html.twig' %}

{% block title %}Mon espace{% endblock %}

{% block body %}
<section class="account-page">
    <div class="container py-5">

        <header class="account-header">
            <div>
                <h1 class="account-title">
                    Bonjour, {{ app.user.username }}
                </h1>

                <p class="account-subtitle">
                    Gérez vos personnages depuis votre espace créateur.
                </p>
            </div>

            <a
                href="{{ path('app_character_new') }}"
                class="btn account-new-button"
            >
                <i class="bi bi-plus-lg"></i>
                Nouveau personnage
            </a>
        </header>

        {% if characters is empty %}
            <div class="account-empty">
                <div class="account-empty-icon">
                    <i class="bi bi-person-plus"></i>
                </div>

                <h2>Vous n’avez pas encore de personnage</h2>

                <p>
                    Commencez à créer votre première légende dans FantasyRealm Online.
                </p>

                <a
                    href="{{ path('app_character_new') }}"
                    class="btn account-new-button"
                >
                    <i class="bi bi-stars"></i>
                    Créer mon premier personnage
                </a>
            </div>
        {% else %}
            <div class="character-account-list">
                {% for character in characters %}
                    <article class="character-account-card">
                        <div class="character-account-main">

                            <div class="character-account-avatar">
                                {% if character.image %}
                                    <img
                                        src="{{ path('app_character_image', {
                                            id: character.id,
                                            v: character.updatedAt ? character.updatedAt.timestamp : character.createdAt.timestamp
                                        }) }}"
                                        alt="Portrait de {{ character.name }}"
                                        class="account-character-image"
                                    >
                                {% else %}
                                    <div class="account-character-image-placeholder">
                                        <i class="bi bi-person"></i>
                                    </div>
                                {% endif %}
                            </div>

                            <div class="character-account-content">
                                <div class="character-heading">
                                    <h2 class="character-account-name">
                                        {{ character.name }}
                                    </h2>

                                    {% if character.authorized %}
                                        <span class="character-status character-status-approved">
                                            <i class="bi bi-check-circle"></i>
                                            Approuvé
                                        </span>
                                    {% else %}
                                        <span class="character-status character-status-pending">
                                            <i class="bi bi-clock"></i>
                                            En attente
                                        </span>
                                    {% endif %}

                                    {% if character.shared %}
                                        <span class="character-status character-status-shared">
                                            <i class="bi bi-globe2"></i>
                                            Partagé
                                        </span>
                                    {% endif %}
                                </div>

                                <p class="character-account-meta">
                                    {{ ('character.gender.' ~ character.gender)|trans }}
                                    <span aria-hidden="true">·</span>
                                    Créé le {{ character.createdAt|date('d/m/Y') }}
                                </p>

                                {% if character.authorized == false %}
                                    <p class="character-account-notice">
                                        <i class="bi bi-info-circle"></i>
                                        En attente de validation par un membre de notre équipe.
                                    </p>
                                {% endif %}
                            </div>
                        </div>

                        <div class="character-account-actions">

                            <a
                                href="{{ path('app_character_edit', {
                                    id: character.id
                                }) }}"
                                class="character-action-button"
                            >
                                <i class="bi bi-pencil"></i>
                                Modifier
                            </a>

                            <form
                                method="post"
                                action="{{ path('app_character_share', {
                                    id: character.id
                                }) }}"
                            >
                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('share' ~ character.id) }}"
                                >

                                <button
                                    type="submit"
                                    class="character-action-button character-action-deploy text-nowrap"
                                >
                                    {% if character.shared %}
                                        <i class="bi bi-eye-slash"></i>
                                        Ne plus partager
                                    {% elseif character.authorized %}
                                        <i class="bi bi-share"></i>
                                        Partager
                                    {% else %}
                                        <i class="bi bi-hourglass-split"></i>
                                        Partager après validation
                                    {% endif %}
                                </button>
                            </form>

                            <form
                                method="post"
                                action="{{ path('app_character_duplicate', {
                                    id: character.id
                                }) }}"
                            >
                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token(
                                        'duplicate-character-' ~ character.id
                                    ) }}"
                                >

                                <button
                                    type="submit"
                                    class="character-action-button"
                                >
                                    <i class="bi bi-copy"></i>
                                    Dupliquer
                                </button>
                            </form>

                            <form
                                method="post"
                                action="{{ path('app_character_delete', {id: character.id}) }}"
                                onsubmit="return confirm(
                                    'Voulez-vous vraiment supprimer ce personnage ?'
                                );"
                            >
                                <input
                                    type="hidden"
                                    name="_token"
                                    value="{{ csrf_token('delete' ~ character.id) }}"
                                >

                                <button
                                    type="submit"
                                    class="character-action-button character-action-delete"
                                >
                                    <i class="bi bi-trash"></i>
                                    Supprimer
                                </button>
                            </form>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}

    </div>
</section>
{% endblock %}
