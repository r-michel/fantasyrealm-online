{% extends 'base.html.twig' %}

{% block body %}
<section class="auth-page">
    <div class="container">

        <div class="auth-logo text-center mb-4">
            <div class="auth-logo-icon mx-auto mb-3">
                <i class="bi bi-crown"></i>
            </div>

            <div class="auth-brand">
                FANTASY<span>REALM</span>
            </div>

            <div class="auth-brand-subtitle">
                ONLINE
            </div>
        </div>

        <div class="auth-card mx-auto">

            {% if active_tab is not null %}
                <div class="auth-tabs mb-4">
                    <a
                        href="{{ path('app_login') }}"
                        class="auth-tab {{ active_tab == 'login' ? 'active' : '' }}"
                    >
                        Connexion
                    </a>

                    <a
                        href="{{ path('app_register') }}"
                        class="auth-tab {{ active_tab == 'register' ? 'active' : '' }}"
                    >
                        Créer un compte
                    </a>
                </div>
                {% endif %}

            {% block auth_form %}{% endblock %}

        </div>

    </div>
</section>
{% endblock %}
