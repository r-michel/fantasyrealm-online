{% extends 'back_office/base.html.twig' %}

{% block title %}
    Journaux d’activité| {{ parent() }}
{% endblock %}

{% block back_office_content %}
<div class="container py-4">

    <section class="activity-log-card">
        <header class="activity-log-card__header">
            <div>
                <h1 class="activity-log-card__title">
                    Journaux d’activité
                    <span class="activity-log-card__count">
                        {{ totalLogs }}
                    </span>
                </h1>

                <p class="activity-log-card__subtitle">
                    Historique des actions réalisées par les utilisateurs,
                    employés et administrateurs.
                </p>
            </div>
        </header>

        {% if logs is empty %}
            <div class="activity-log-empty">
                <i class="bi bi-clock-history"></i>

                <p>
                    Aucun journal d’activité n’a encore été enregistré.
                </p>
            </div>
        {% else %}
            <div class="activity-log-table-wrapper">
                <table class="activity-log-table">
                    <thead>
                        <tr>
                            <th scope="col">Date</th>
                            <th scope="col">Utilisateur</th>
                            <th scope="col">Cible</th>
                            <th scope="col">Action</th>
                            <th scope="col">Détail</th>
                        </tr>
                    </thead>

                    <tbody>
                        {% for log in logs %}
                            <tr>
                                <td
                                    class="activity-log-date"
                                    data-label="Date"
                                >
                                    {% if log.date %}
                                        <time
                                            datetime="{{ log.date|date('c') }}"
                                            title="{{ log.date|date('d/m/Y à H:i:s') }}"
                                        >
                                            {{ log.date|date('d/m/Y H:i') }}
                                        </time>
                                    {% else %}
                                        <span>—</span>
                                    {% endif %}
                                </td>

                                <td
                                    class="activity-log-actor"
                                    data-label="Utilisateur"
                                >
                                    <strong>
                                        {{ log.actor }}
                                    </strong>

                                    <small>
                                        {{ log.actorType }}
                                    </small>
                                </td>

                                <td
                                    class="activity-log-target"
                                    data-label="Cible"
                                >
                                    <strong>
                                        {{ log.target }}
                                    </strong>

                                    <small>
                                        {{ log.targetType }}
                                    </small>
                                </td>

                                <td
                                    class="activity-log-action"
                                    data-label="Action"
                                >
                                    <span
                                        class="activity-log-badge {{ log.actionClass }}"
                                    >
                                        {{ log.action }}
                                    </span>
                                </td>

                                <td
                                    class="activity-log-detail"
                                    data-label="Détail"
                                >
                                    <span title="{{ log.message }}">
                                        {{ log.detail }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {% if totalPages > 1 %}
                <nav
                    class="activity-log-pagination"
                    aria-label="Pagination des journaux"
                >
                    {% if currentPage > 1 %}
                        <a
                            href="{{ path(
                                'app_back_office_activity_log_index',
                                {
                                    page: currentPage - 1
                                }
                            ) }}"
                            class="activity-log-pagination__link"
                            aria-label="Page précédente"
                        >
                            <i class="bi bi-chevron-left"></i>
                            Précédent
                        </a>
                    {% else %}
                        <span
                            class="activity-log-pagination__link disabled"
                            aria-disabled="true"
                        >
                            <i class="bi bi-chevron-left"></i>
                            Précédent
                        </span>
                    {% endif %}

                    <span class="activity-log-pagination__status">
                        Page {{ currentPage }} sur {{ totalPages }}
                    </span>

                    {% if currentPage < totalPages %}
                        <a
                            href="{{ path(
                                'app_back_office_activity_log_index',
                                {
                                    page: currentPage + 1
                                }
                            ) }}"
                            class="activity-log-pagination__link"
                            aria-label="Page suivante"
                        >
                            Suivant
                            <i class="bi bi-chevron-right"></i>
                        </a>
                    {% else %}
                        <span
                            class="activity-log-pagination__link disabled"
                            aria-disabled="true"
                        >
                            Suivant
                            <i class="bi bi-chevron-right"></i>
                        </span>
                    {% endif %}
                </nav>
            {% endif %}
        {% endif %}
    </section>
</div>
{% endblock %}
