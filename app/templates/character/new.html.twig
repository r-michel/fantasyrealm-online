{% extends 'base.html.twig' %}

{% block title %}Créer un personnage{% endblock %}

{% block body %}
<section class="character-builder">
    <div class="container py-5">

        <a
            href="{{ path('app_account') }}"
            class="builder-back-link"
        >
            <i class="bi bi-chevron-left"></i>
            Mon espace
        </a>

        <h1 class="builder-page-title">
            Créer un personnage
        </h1>

        {% include 'character/_form.html.twig' with {
            characterForm: characterForm,
            submitLabel: 'Soumettre à validation',
            submitIcon: 'bi-stars',
            submitHelp:
                'Le nom sera validé par notre équipe. Vous pourrez modifier l’équipement à tout moment.'
        } only %}

    </div>
</section>
{% endblock %}

{% block javascripts %}
    {{ parent() }}

    {% include 'character/_builder_scripts.html.twig' with {
        characterForm: characterForm
    } only %}
{% endblock %}
