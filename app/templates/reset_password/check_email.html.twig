{% extends 'auth/_auth_card.html.twig' %}

{% set active_tab = null %}

{% block title %}Consultez votre boîte mail{% endblock %}

{% block auth_form %}
    <div class="auth-status text-center">
        <div class="auth-status-icon mx-auto mb-4">
            <i class="bi bi-envelope-check"></i>
        </div>

        <h1 class="auth-form-title">
            Consultez vos emails
        </h1>

        <p class="auth-form-description">
            Si un compte correspond à l’adresse indiquée, un lien de réinitialisation vient de vous être envoyé.
        </p>

        <p class="auth-form-description mt-3">
            Ce lien expirera dans
            {{ resetToken.expirationMessageKey|trans(resetToken.expirationMessageData, 'ResetPasswordBundle') }}.
        </p>

        <a href="{{ path('app_login') }}" class="btn auth-submit w-100 mt-4">
            Retour à la connexion
        </a>
    </div>
{% endblock %}
