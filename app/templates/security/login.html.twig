{% extends 'auth/_auth_card.html.twig' %}

{% set active_tab = 'login' %}

{% block title %}Connexion{% endblock %}

{% block auth_form %}

<form method="post">

    {% if error %}
        <div class="alert alert-danger">
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
    {% endif %}

    <div class="mb-4">
        <label for="username" class="auth-label">Adresse e-mail</label>

        <div class="auth-input-wrapper">
            <i class="bi bi-envelope"></i>
            <input
                type="email"
                value="{{ last_username }}"
                name="_username"
                id="username"
                class="auth-input"
                autocomplete="email"
                placeholder="votre@email.com"
                required
                autofocus
            >
        </div>
    </div>

    <div class="mb-4">
        <label for="password" class="auth-label">Mot de passe</label>

        <div class="auth-input-wrapper">
            <i class="bi bi-lock"></i>
            <input
                type="password"
                name="_password"
                id="password"
                class="auth-input"
                autocomplete="current-password"
                placeholder="••••••••"
                required
            >
        </div>
    </div>

    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

    <button class="btn auth-submit w-100" type="submit">
        <i class="bi bi-crown me-2"></i>
        Entrer dans le Royaume
    </button>

</form>

{% endblock %}
